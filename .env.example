# Copie este arquivo para ".env" e preencha a chave.
# Pegue sua chave em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Porta do servidor (opcional)
PORT=3000

# Modelo usado para ler os prints (opcional).
# Vision + structured outputs. Opções (jun/2026):
#   gpt-5.4-mini  -> recomendado (preciso e barato)
#   gpt-5.4-nano  -> mais barato
#   gpt-5.4       -> máxima precisão
#   gpt-4o        -> só se sua conta tiver acesso ao legado
OPENAI_MODEL=gpt-5.4-mini
